  <property name="styleSheet">
   <string notr="true">QDialog {
    background-color: #1e1f26;
}

QWidget#mainPanel {
    background-color: #2a2c36;
    border: 1px solid #3a3d4a;
    border-radius: 18px;
}

QWidget#formSection,
QWidget#summarySection {
    background-color: #242631;
    border: 1px solid #3a3d4a;
    border-radius: 14px;
}

QLabel {
    color: #dfe6ee;
    font-size: 15px;
    font-weight: 600;
    background: transparent;
    border: none;
}

QLabel#titleLabel {
    color: #ffffff;
    font-size: 26px;
    font-weight: bold;
    padding: 8px 0 10px 0;
    qproperty-alignment: AlignCenter;
}

QLabel#subtitleLabel {
    color: #bfc7d5;
    font-size: 14px;
    font-weight: 500;
    padding: 0 0 4px 0;
    qproperty-alignment: AlignCenter;
}

QLabel#totalLabel {
    color: #bfc7d5;
    font-size: 16px;
    font-weight: bold;
    qproperty-alignment: AlignCenter;
}

QSpinBox {
    background-color: #f4f7fb;
    color: #1e1f26;
    border: 2px solid #d0d7e2;
    border-radius: 10px;
    padding-top: 6px;
    padding-bottom: 6px;
    padding-left: 10px;
    padding-right: 28px;
    min-height: 24px;
    min-width: 140px;
    font-size: 14px;
}

QSpinBox:hover {
    border: 2px solid #2f80ed;
}

QSpinBox:focus {
    border: 2px solid #2f80ed;
}

QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 22px;
    background-color: #eef3f9;
    border-left: 1px solid #d0d7e2;
    border-top-right-radius: 8px;
}

QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 22px;
    background-color: #eef3f9;
    border-left: 1px solid #d0d7e2;
    border-top: 1px solid #d0d7e2;
    border-bottom-right-radius: 8px;
}

QSpinBox::up-button:hover,
QSpinBox::down-button:hover {
    background-color: #dfe9f7;
}

QSpinBox::up-button:pressed,
QSpinBox::down-button:pressed {
    background-color: #cfdced;
}

QSpinBox::up-arrow,
QSpinBox::down-arrow {
    width: 10px;
    height: 10px;
}

QPushButton {
    background-color: #2f80ed;
    color: white;
    border-radius: 12px;
    padding: 12px;
    font-size: 15px;
    font-weight: 600;
    border: none;
    min-height: 44px;
}

QPushButton:hover {
    background-color: #3c94ff;
}

QPushButton:pressed {
    background-color: #256fd1;
}

QPushButton#cancelButton {
    background-color: #6c757d;
}

QPushButton#cancelButton:hover {
    background-color: #7b848c;
}

QPushButton#cancelButton:pressed {
    background-color: #5c646b;
}

QSpinBox::up-arrow {
	image: url(:/icons/arrow_up.svg);
    width: 15px;
    height: 15px;
}

QSpinBox::down-arrow {
	image:  url(:/icons/arrow_down.svg);
    width: 15px;
    height: 15px;
}</string>
