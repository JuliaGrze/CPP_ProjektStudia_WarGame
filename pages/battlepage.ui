  <property name="styleSheet">
   <string notr="true">QFrame#mainPanel {
    background-color: #565e68;
    border: 1px solid #6f7782;
    border-radius: 14px;
}

QFrame#topPanel,
QFrame#bottomPanel {
    background: transparent;
    border: none;
}

QFrame#leftInfoPanel,
QFrame#boardOuterFrame,
QFrame#rightActionsPanel,
QFrame#battleLogPanel,
QFrame#turnPanel,
QFrame#teamsPanel {
    background-color: #1f2937;
    border: 1px solid #c9d1d9;
    border-radius: 14px;
}

QFrame#leftInfoPanel {
    background-color: #111827;
    border: 2px solid #fbbf24;
}

QFrame#teamsPanel {
    background-color: #111827;
    border: 2px solid #60a5fa;
}

QFrame#turnPanel {
    background-color: #111827;
    border: 2px solid #34d399;
}

QFrame#battleLogPanel {
    background-color: #111827;
    border: 2px solid #9ca3af;
}

QFrame#boardContainer {
    background-color: #111827;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
}

QLabel {
    color: white;
    background: transparent;
    border: none;
    font-size: 13px;
}

QLabel#labelInfoTitle,
QLabel#labelActionsTitle,
QLabel#labelBattleLogTitle,
QLabel#labelTurnTitle,
QLabel#labelTeamsTitle {
    font-size: 16px;
    font-weight: 800;
    padding-bottom: 8px;
    color: #f9fafb;
}

QLabel#labelUnitName,
QLabel#labelTurnNumber,
QLabel#labelTeamsInfo {
    font-size: 15px;
    font-weight: 700;
}

QLabel#labelUnitStats,
QLabel#labelBattleLog {
    font-size: 14px;
    color: #e5e7eb;
}

QPushButton {
    background-color: #374151;
    color: white;
    border: 1px solid #d1d5db;
    border-radius: 10px;
    padding: 8px 12px;
    min-height: 40px;
    font-weight: 700;
}

QPushButton:hover {
    background-color: #4b5563;
}

QPushButton:pressed {
    background-color: #6b7280;
}

QPushButton#btnEndTurn {
    background-color: #2f80ed;
    border: 1px solid #99f6e4;
}

QPushButton#btnEndTurn:hover {
    background-color: #115e59;
}

QPushButton#btnBackToMenu {
    background-color: #eb5757;
    border: 1px solid #fca5a5;
}

QPushButton#btnBackToMenu:hover {
    background-color: #991b1b;
}

QLabel#labelTileInfoTitle,
QLabel#labelLegendTitle {
    font-size: 15px;
    font-weight: 700;
    color: #f9fafb;
    padding-top: 6px;
    padding-bottom: 4px;
}

QLabel#labelTileInfo,
QLabel#labelLegend {
    font-size: 13px;
    color: #e5e7eb;
}</string>
