}

/* Scrollbar */
QScrollBar:vertical {
    border: none;
    background: #2a2c36;
    width: 10px;
    margin: 4px 0 4px 0;
}

QScrollBar::handle:vertical {
    background: #555b6e;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #6c7390;
}

/* Button */
QPushButton {
